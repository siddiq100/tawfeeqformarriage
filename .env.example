# ====== الخادم ======
PORT=5000
NODE_ENV=production

# ====== قاعدة البيانات MongoDB ======
# استخدم MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# تنسيق: mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/tawfeeq?retryWrites=true&w=majority

# ====== الأمان والمصادقة ======
# استخدم مفتاح عشوائي قوي (32+ حرف)
JWT_SECRET=your_very_secure_random_jwt_secret_key_here_at_least_32_characters_long

# ====== البريد الإلكتروني (التحقق من الحسابات) ======
# استخدم Gmail مع App Passwords: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_from_google

# ====== الإدارة ======
ADMIN_EMAIL=siddiqa@tawfeeq.com
ADMIN_PASSWORD=your_secure_admin_password_here

# ====== الواجهة الأمامية (Client) ======
# رابط الموقع في الإنتاج
CLIENT_URL=https://your-frontend-domain.com
CORS_ORIGIN=https://your-frontend-domain.com

# ====== المتغيرات المحلية (للتطوير فقط) ======
# في التطوير المحلي استخدم:
# PORT=5000
# MONGO_URI=mongodb://localhost:27017/tawfeeq
# JWT_SECRET=dev_secret_key_for_testing_only
# CLIENT_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
